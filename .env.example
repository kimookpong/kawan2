# Supabase — คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ใช้ฝั่ง server เท่านั้น (server actions / edge functions) — ห้าม expose ไป client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL ของเว็บ (สำหรับ auth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Stripe (ระบบ subscription) -----
# จาก Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxx
# จาก Stripe CLI หรือ Dashboard > Webhooks (signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price ID ของแต่ละแพ็กเกจ (Products > Pricing) — เป็นแบบ recurring/monthly
STRIPE_PRICE_SUPPORTER=price_xxx
STRIPE_PRICE_PATRON=price_xxx



FIRECRAWL_API_KEY=fc-xxx
